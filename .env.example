# Path to Chromium/Chrome executable. Leave unset to use Playwright's bundled browser (e.g. on Mac).
# On Raspberry Pi, set to system Chromium:
# CHROMIUM_PATH=/usr/bin/chromium-browser

# Rent server API base URL (used by getRentByLink). Default: http://localhost:3000
# RENT_SERVER_URL=http://localhost:3000
